# Costruzione del Prompt
def generate_user_profile(contextual_reviews):
    joined_reviews = "\n\n".join(contextual_reviews)

    prompt = f"""

Summarize the user's videogame preferences in ONE concise sentence.
The sentence should describe:
- preferred genres
- preferred gameplay style
- key elements the user values

Do NOT use bullet points.
Do NOT use headings.
Write a single, fluent sentence.

Contextualized reviews:
{joined_reviews}

"""
    
# Definizione del modello da usare per gemini
    response = client.models.generate_content(
        model="models/gemini-2.5-pro",
        contents=prompt
    )

    return response.text.strip()

# Qui andiamo a dire di quanti utenti dobbiamo generare il profilo utente 
def main():
    NUM_USERS = 2  # numero di profili da generare

    for i, (user_id, contexts) in enumerate(user_contexts.items()):
        if i >= NUM_USERS:
            break

        profile_text = generate_user_profile(contexts)

        print(f"\n=== PROFILO UTENTE {i+1} (user_id: {user_id}) ===\n")
        print(profile_text)

if __name__ == "__main__":
    main()

