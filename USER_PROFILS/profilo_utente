import json

# Caricamento dati gioco
with open("/home/marino/tesi/dataset_clean/steam_games_clean.json", "r", encoding="utf-8") as f:
    games_data = json.load(f)

# Creazione del dizionario: game_id -> info gioco
games_by_id = {g["id"]: g for g in games_data}

# Caricamento delle recensioni
reviews_data = []

with open("/home/marino/tesi/dataset_clean/steam_reviews_reduced.jsonl", "r", encoding="utf-8") as f:
    for line in f:
        reviews_data.append(json.loads(line))

# Funzione safe_join --> Permette di andare a prevenire degli errori che si possono avere con il modello a causa di campi particolari
def safe_join(value):
    if isinstance(value, list):
        return ", ".join(value)
    if isinstance(value, str):
        return value
    return "N/A"

# Andiamo a collegare la recensione al gioco così da avere maggiori informazioni riguardo al gioco
def build_contextual_review(review_text, game):
    return f"""
Game title: {game.get('title', 'N/A')}
Genres: {safe_join(game.get('genres'))}
Tags: {safe_join(game.get('tags'))}
Developer: {game.get('developer', 'N/A')}

User review:
{review_text}
"""

# Permette di raggrupare tutte le recensione dello stesso utente  
from collections import defaultdict

user_contexts = defaultdict(list)

# Creazione del contesto per ogni utente 
for r in reviews_data:
    game = games_by_id.get(r["product_id"])
    if game is None:
        continue

    contextual_text = build_contextual_review(
        r["text"],
        game
    )

    user_contexts[r["user_id"]].append(contextual_text)

# Andiamo ad utilizzare un numero massimo di 5 recensioni 
MAX_REVIEWS = 5  

for user_id in user_contexts:
    user_contexts[user_id] = user_contexts[user_id][:MAX_REVIEWS]

# Definzione delle chiave per l'uso di Gemini API
from google import genai


client = genai.Client(
    api_key="AIzaSyCpgWjNDycIZTHKRI7z8mR54KA26pE8Sh0"
